# Lavalink (Render)
# Preferred (bot + lavalink are both on Render, same region; Lavalink is a PRIVATE service):
# - set host to the Render service name (internal DNS)
# - use port 2333 and non-TLS websocket
LAVALINK_HOST=rcif-lavalink
LAVALINK_PORT=2333
LAVALINK_PASSWORD=rcif123
LAVALINK_SECURE=false
LAVALINK_NODE_ID=main

# Optional (Render auto-mode only):
# If you don't set LAVALINK_HOST, the bot tries these defaults.
LAVALINK_INTERNAL_HOST=rcif-lavalink
LAVALINK_PUBLIC_HOST=rcif-lavalink.onrender.com
