# ═══════════════════════════════════════════════════════════
# Lyn Dashboard V2 — Environment Variables Template
# انسخ هذا الملف إلى .env واملأ القيم
# ═══════════════════════════════════════════════════════════

# ── Backend API ──
VITE_API_URL=https://your-api.onrender.com

# ── Discord OAuth ──
VITE_DISCORD_CLIENT_ID=your_discord_client_id
VITE_DISCORD_REDIRECT_URI=http://localhost:5173/callback

# ── Bot ──
VITE_BOT_NAME=Lyn
VITE_BOT_INVITE_URL=https://discord.com/oauth2/authorize?client_id=YOUR_BOT_ID&permissions=8&scope=bot%20applications.commands

# ── Owner ──
VITE_OWNER_ID=your_discord_user_id

# ── Features ──
VITE_ENABLE_DARK_MODE=true
VITE_ENABLE_ANALYTICS=false
